{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MPRetention",
  "version": "1.0.3",
  "identifier": "com.sinergigroup.mpretention",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MPRetention",
        "width": 1280,
        "height": 800,
        "minWidth": 1280,
        "minHeight": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libssl3t64", "libayatana-appindicator3-1"]
      }
    }
  },
  "plugins": {
    "sql": {}
  }
}
